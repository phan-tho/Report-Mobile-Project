#!/bin/sh
# Chặn push thẳng lên main — dùng feature branch + PR thay thế.

REMOTE="$1"
BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if [ "$BRANCH" = "main" ] && [ "$REMOTE" = "origin" ]; then
    echo ""
    echo "BLOCKED: không được push thẳng lên main."
    echo "Dùng feature branch + PR:"
    echo "  git checkout -b feat/<tên-feature>"
    echo "  git push origin feat/<tên-feature>"
    echo "  gh pr create"
    echo ""
    echo "Nếu THẬT SỰ cần push thẳng: git push --no-verify origin main"
    exit 1
fi

# Nhắc tạo PR sau khi push feature branch thành công
if [ "$REMOTE" = "origin" ] && [ "$BRANCH" != "main" ]; then
    echo ""
    echo "Tip: Tạo PR với lệnh: gh pr create --base main"
fi
exit 0
