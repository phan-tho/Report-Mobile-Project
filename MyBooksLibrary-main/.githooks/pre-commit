#!/bin/sh
# Pre-commit hook: lintDebug + ktlintCheck + detekt khi có staged .kt files.
# Cài tự động qua Gradle task installGitHooks (chạy khi build lần đầu).

STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)

# Strings parity: chuỗi UI mới/sửa phải có ở CẢ values/ lẫn values-vi/
# (refactor-ui-ux.md §8). Đặt TRƯỚC early-exit vì commit chỉ sửa strings.xml
# không có file .kt staged.
if echo "$STAGED_ALL" | grep -q 'res/values[^/]*/strings\.xml'; then
    if ! sh scripts/check-strings-parity.sh; then
        exit 1
    fi
fi

STAGED_KT=$(echo "$STAGED_ALL" | grep '\.kt$')
if [ -z "$STAGED_KT" ]; then
    exit 0
fi

# --- Fast-fail: phát hiện pattern sai trước khi chạy Gradle (~1 giây) ---
FAST_FAIL=0

# Design tokens: cấm hardcode màu/cỡ chữ/font ngoài ui/theme/ (refactor-ui-ux.md §7B)
if ! sh scripts/check-design-tokens.sh; then
    FAST_FAIL=1
fi

# junit4.v2.createComposeRule không generate coverage ổn định — dùng createAndroidComposeRule
if echo "$STAGED_KT" | xargs grep -l "junit4\.v2\.createComposeRule" 2>/dev/null | grep -q .; then
    echo "❌ junit4.v2.createComposeRule — đổi sang createAndroidComposeRule<ComponentActivity>()"
    echo "   Files vi phạm:"
    echo "$STAGED_KT" | xargs grep -l "junit4\.v2\.createComposeRule" 2>/dev/null | sed 's/^/     /'
    FAST_FAIL=1
fi

# junit4.v2.createAndroidComposeRule: v2 dùng StandardTestDispatcher, không generate coverage ổn định
# Deprecation warning từ Compose khuyến khích migrate lên v2 — KHÔNG làm theo, giữ v1
if echo "$STAGED_KT" | xargs grep -l "junit4\.v2\.createAndroidComposeRule" 2>/dev/null | grep -q .; then
    echo "❌ junit4.v2.createAndroidComposeRule — giữ v1: createAndroidComposeRule<ComponentActivity>()"
    echo "   v2 dùng StandardTestDispatcher, không generate coverage ổn định dù Compose khuyến khích migrate"
    echo "   Files vi phạm:"
    echo "$STAGED_KT" | xargs grep -l "junit4\.v2\.createAndroidComposeRule" 2>/dev/null | sed 's/^/     /'
    FAST_FAIL=1
fi

# createEmptyComposeRule gây 'No compose hierarchies found' trong HiltAndroidTest
if echo "$STAGED_KT" | xargs grep -l "createEmptyComposeRule" 2>/dev/null | grep -q .; then
    echo "❌ createEmptyComposeRule — dùng createAndroidComposeRule<ComponentActivity>()"
    echo "   Files vi phạm:"
    echo "$STAGED_KT" | xargs grep -l "createEmptyComposeRule" 2>/dev/null | sed 's/^/     /'
    FAST_FAIL=1
fi

# Room DB version bump không có Migration → crash app khi user upgrade.
# Logic gate nằm trong scripts/check-room-migration.sh (dùng chung với CI) —
# grep cũ inline ở đây đã chết khi AppDatabase.kt chuyển sang version = CONSTANT (issue #94).
if echo "$STAGED_KT" | grep -q "AppDatabase.kt"; then
    # old = HEAD, new = staged index (ref rỗng)
    if ! sh scripts/check-room-migration.sh "HEAD" ""; then
        FAST_FAIL=1
    fi
fi

if [ $FAST_FAIL -ne 0 ]; then
    exit 1
fi
# --- End fast-fail ---

if [ -f "./gradlew" ]; then
    GRADLEW="./gradlew"
else
    echo "Không tìm thấy gradlew — bỏ qua kiểm tra."
    exit 0
fi

echo ">>> lint + ktlint + detekt: kiểm tra staged .kt files..."

"$GRADLEW" lintDebug ktlintCheck detekt --console=plain -q
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "FAILED — sửa violations rồi commit lại."
    echo "  lint:   app/build/reports/lint-results-debug.html"
    echo "  ktlint: chạy './gradlew ktlintFormat' để auto-fix (*.kt đã có eol=lf, hoạt động trên mọi OS)."
    echo "  detekt: app/build/reports/detekt/detekt.html"
    exit $STATUS
fi

echo ">>> unit test: chạy toàn bộ test JVM..."

"$GRADLEW" :app:testDebugUnitTest --console=plain -q
TEST_STATUS=$?

if [ $TEST_STATUS -ne 0 ]; then
    echo ""
    echo "FAILED — có unit test fail, xem report tại:"
    echo "  app/build/reports/tests/testDebugUnitTest/index.html"
fi
exit $TEST_STATUS
